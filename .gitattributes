# Force LF for all text — avoids the LF→CRLF Windows warnings and keeps
# the DevContainer (Linux) and the CI runners reading the same bytes.
* text=auto eol=lf

# Java + Maven sources
*.java     text eol=lf
*.xml      text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.html     text eol=lf
*.css      text eol=lf

# Shell scripts and Dockerfiles must be LF for Linux to execute them
*.sh        text eol=lf
Dockerfile  text eol=lf
*.dockerignore text eol=lf

# Binary files — let git treat them as opaque
*.jar      binary
*.png      binary
*.jpg      binary
*.gif      binary
*.pdf      binary
