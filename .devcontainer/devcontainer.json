{
    "name": "DiscoveriesBattleshipGame Dev",

    "build": {
        "dockerfile": "Dockerfile"
    },

    // Extra features layered on top of the Dockerfile
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
            "moby": false
        }
    },

    // IDE-specific recommendations
    "customizations": {
        "vscode": {
            "extensions": [
                "vscjava.vscode-java-pack",
                "vscjava.vscode-maven",
                "ms-azuretools.vscode-docker",
                "github.vscode-github-actions",
                "yzhang.markdown-all-in-one",
                "redhat.vscode-yaml"
            ],
            "settings": {
                "java.configuration.updateBuildConfiguration": "automatic",
                "files.eol": "\n"
            }
        },
        "jetbrains": {
            "backend": "IntelliJ",
            "plugins": [
                "org.jetbrains.plugins.github",
                "Docker"
            ]
        }
    },

    // After the container is created, warm the Maven cache and run the test
    // suite. Tests now compile (AppTest was migrated to JUnit Jupiter), so the
    // post-create command gives a free smoke check that the environment works.
    "postCreateCommand": "mvn -B -q dependency:go-offline && mvn -B -q clean test",

    // Non-root user provided by the base image
    "remoteUser": "vscode"
}

